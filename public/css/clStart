	while opcionConSep="$(zenity --title "CLUSTER TEST " --ok-label="run" --height=300 --width=300 --list --text="Pruebas" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE "Cluster Test" \
	FALSE "Encender UIDs" \
	FALSE "Apagar UIDs" \
	FALSE "Ping" \
	FALSE "Tail" \
	FALSE "Reiniciar Servicios" \
	FALSE "Subir Logs ")"; do

	op1ConSep="Cluster Test"
	op2ConSep="Encender UIDs"
	op3ConSep="Apagar UIDs"
	op4ConSep="Ping"
	op5ConSep="Tail"
	op6ConSep="Reiniciar Servicios"
	op7ConSep="Subir Logs "

	case $opcionConSep in
		$op1ConSep)	#"Cluster Test"
			if [ "$fail" == 0 ];then
				validSnRack
			else
				fail=$fail+1
			fi
			if [ "$fail" == 0 ];then
				if [ -e /kit/macaddrs/$snRack.csv ]; then
					rm -rf /opt/clustertest/logs/*.csv
					ct_configure_vm $snRack | zenity --progress --width=200  --pulsate --text="Corriendo ct_configure_vm"  --title="CT_CONFIGURE_VM" --auto-close --auto-kill
