#MODIFICAR ASSET TAG (FIX_ASSET_TAG)
function cambioAsset {
	if [ $# -ne 2 ]; then
		echo "Missing information. Node name and asset tag needed.Ex: ./fix_asset_tag.sh NodeXYZ 1234567"
		exit 9
	fi
	progpath=`which $0`
	bindir=/opt/hp/hp-scripting-tools
	node_name=$1
	asset_tag=$2
	asset_tag_template=$bindir/etc/asset_tag_file.xml
	asset_tag_input=$bindir/etc/$node_name.xml
	conrep_definition=$bindir/etc/conrep.xml

	sed  -e "s/\%ASSET_TAG\%/$asset_tag/" "$asset_tag_template" > $asset_tag_input
	if [ $? -ne 0 ] ; then
		echo "Failed to generate asset tag file with error code: $?"
		exit 10
	fi
	pdsh -w $node_name conrep -l -x $conrep_definition -f $asset_tag_input
	if [ $? -ne 0 ] ; then
		echo "Failed to burn in asset tag with error code: $?"
		exit 11
	else
		rm -f $asset_tag_input
	fi
	sleep 1
}

