				pdsh -a -x node100 hpasmcli -s "set\ uid\ on" | zenity --progress --width=200  --pulsate --text="Por favor espere"  --title="UIDs ON" --auto-close --auto-kill
			else
				zenity --error --title="ERROR" --text="Verifique que el rack esta conectado"
			fi
		;;
		$op3ConSep)	#"Apagar UIDs"
			pdsh -a -x node100 dmidecode -t1 | grep Serial | sort >> /root/Serial.txt
			if [ -s /root/Serial.txt ]; then
				pdsh -a -x node100 hpasmcli -s "set\ uid\ off" | zenity --progress --width=200  --pulsate --text="Por favor espere"  --title="UIDs OFF" --auto-close --auto-kill
			else
				zenity --error --title="ERROR" --text="Verifique que el rack esta conectado"
			fi
		;;
		$op4ConSep)	#"Ping"
			pingNode
		;;
		$op5ConSep) #"Tail"
			gnome-terminal -e "tailf /var/log/messages" &
		;;
		$op6ConSep) #"Reiniciar servicios"
			menuReinicioServicios
		;;
		$op7ConSep)	#"Subir Logs"
		  	valSnLogs
			if [ "$fail" == "0" ];then
				firefox ftp://Admin:Password123@172.16.1.245/CTlogs/Azure%20$tipoRack%20ClusterTest/WO%20$wo/ &
			else
				fail=$fail+1
			fi
		;;
		*)
			zenity --Error --title="Error" --text="Error"
			exit
		;;
	esac
done
}

#MENU PARA VERIFICAR INFORMACION
function menuVer {
	while opcionConVer="$(zenity --title "CLUSTER TEST" --height=280 --width=300 --list --text="Verificar" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE "Verificar Servicios" \
	FALSE "Verificar Asset Tag" \
	FALSE "Verificar Numeros de serie" \
	FALSE "Verificar MAC-ADDRESS" \
	FALSE "Verificar Conexion" \
	FALSE "Verificar ROM" \
	FALSE "Verificar iLo ")"; do

	op1ConVer="Verificar Servicios"
	op2ConVer="Verificar Asset Tag"
	op3ConVer="Verificar Numeros de serie"
	op4ConVer="Verificar MAC-ADDRESS"
	op5ConVer="Verificar Conexion"
	op6ConVer="Verificar ROM"
	op7ConVer="Verificar iLo "

	case $opcionConVer in
		$op1ConVer)	#"Verificar Servicios"
			exec 3> >(zenity --progress --title="Verificando Servicios" --pulsate --auto-close --auto-kill)
		 	VerificarServicios>&3
		  	exec 3>&-
			zenity --info --title="Servicios" --text="Servicios funcionando!!"
		;;
		$op2ConVer)	#"Verificar Asset Tag"
			exec 3> >(zenity --progress --title="Verificando Asset Tag" --pulsate --auto-close --auto-kill)
		 	verificarAsset>&3
		  	exec 3>&-
		;;
		$op3ConVer)	#"Verificar Numeros de serie"
			exec 3> >(zenity --progress --title="Verificando Numero de Serie" --pulsate --auto-close --auto-kill)
		 	verificarSerial>&3
		  	exec 3>&-
		;;
		$op4ConVer)	#"Verificar MAC-ADDRESS"
			validSnRack
			if [ "$fail" == 0 ]; then
				if [ -e /opt/clustertest/logs/$snRack.csv ]; then
					zenity --text-info --title="MAC-Address de $snRack" --height=900 --width=350 --filename=/opt/clustertest/logs/$snRack.csv
				else
					if [ -e /kit/macaddrs/$snRack.csv ]; then
						zenity --text-info --title="MAC-Address de $snRack" --filename=/kit/macaddrs/$snRack.csv
					else
						zenity --error --title="ERROR" --text="No se encontraron MAC-address"
					fi
				fi
			else
				fail=$fail+1
			fi
		;;
		$op5ConVer)
			exec 3> >(zenity --progress --title="ENCENDER UIDS" percentage=0 --auto-close --auto-kill)
			temporizador>&3
			exec 3>&-
		;;
		$op6ConVer)
		pdsh -a -x node100 dmidecode |grep 'ROM\|v1.3' |dshbak -c > /root/romInfo.txt
		zenity --text-info --width=390 --height=300 --filename=/root/romInfo.txt --title="INFORMACION DE ROM"
		rm -f /root/romInfo.txt
		;;
		$op7ConVer)
		pdsh -a -x node100 hponcfg -g | grep -i "3.01" | sort > /root/iLoinfo.txt
		zenity --text-info --width=550 --height=700 --filename=/root/iLoinfo.txt --title="INFORMACION iLO"
		rm -f /root/iLoinfo.txt
		;;
		*)
			zenity --Error --text="Error"
			exit
		;;
	esac
done
}

#MENU PARA MODIFICAR INFORMACION
function menuMod {
	while opcionConMod="$(zenity --title "CLUSTER TEST" --height=280 --width=300 --list --text="Modificar" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE "Modificar Seriales y Asset Tags" \
	FALSE "Modificar Asset Tag" \
	FALSE "Modificar Numero de Serie" \
	FALSE "Reemplazar MAC-ADDRESS" \
	FALSE "Apply_Bios_Settings ")"; do

	op1ConMod="Modificar Seriales y Asset Tags"
	op2ConMod="Modificar Asset Tag"
	op3ConMod="Modificar Numero de Serie"
	op4ConMod="Reemplazar MAC-ADDRESS"
	op5ConMod="Apply_Bios_Settings "

	case $opcionConMod in
		$op1ConMod)	#"Modificar Seriales y Asset Tags"
			validSnRack
			if [ "$fail" == 0 ];then
				exec 3> >(zenity --progress --title="Comprobando BIOS de nodos" --pulsate --auto-close --auto-kill)
			 	modificarInformacion>&3
		  		exec 3>&-
			else
				fail=$fail+1
			fi
		;;
		$op2ConMod)	#"Modificar Asset Tag"
		pdsh -a -x node100 dmidecode -t1 | grep Serial | sort >> /root/Serial.txt
		if [ -s /root/Serial.txt ];then
			numNodo=$(zenity --entry --text="Introduzca numero de nodo" title="Modifocar Asset Tag" --entry-text="node101")
			longnumNodo=${#numNodo}
			fail=0
			if [ $longnumNodo != 7 ]; then
				zenity --error --title="Error" --text="La longitud del nodo es incorrecta"
				fail=$fail+1
			else
				nvoAsset=$(zenity --entry --text="Introduzca Asset" title="Modificar Asset Tag")
				longNvoAsset=${#nvoAsset}
				if [ $longNvoAsset != 7 ];then
					zenity --error --title="Error" --text="La longitud del Asset Tag es incorrecta"
					fail=$fail+1
				else
					cambioAsset $numNodo $nvoAsset #--###& zenity --progress --title="Modificando AssetTag" --text="Guardando los cambios" --pulsate --auto-close --auto-kill ###--#
					pdsh -w $numNodo reboot & zenity --info --text="El $numNodo se rebooteara" --title="Asset Tag"
				fi
			fi
		else
			zenity --error --title="Error" --text="Verifique que el Rack este conectado"
		fi
		rm -rf /root/Serial.txt
		;;
		$op3ConMod)	#"Modificar Numero de Serie"
		pdsh -a -x node100 dmidecode -t1 | grep Serial | sort >> /root/Serial.txt
		if [ -s /root/Serial.txt ];then
			numNodoX=$(zenity --entry --text="Introduzca numero de nodo" title="Modificar Serial" --entry-text="node101")
			snNodoX=$(zenity --entry --text="Introduzca Nuevo Numero de Serie" title="Modificar Serial")
			snNodo=$(echo $snNodo | tr [:lower:] [:upper:])
			formatSnNodo=$(echo $snNodoX | cut -c 1-3)
			longSnNodo=${#snNodoX}
			exec 3> >(zenity --progress --title="Modificando Numero de Serie" --pulsate --auto-close --auto-kill)
		  	serialConrep>&3
		  	exec 3>&-
		  	pdsh -w node$num conrep -l -f /root/serial-number.xml
			pdsh -w node$num reboot -h now
			rm -f /root/serial-number.xml
		else
			zenity --error --title="Error" --text="Verifique que el Rack este conectado"
		fi
		rm -rf /root/Serial.txt
		;;
		$op4ConMod)	#"Reemplazar MAC-ADDRESS"
			numnodomac=$(zenity --entry --text="Introduzca el numero del nodo" title="Reemplazo de MAC-Addres" --entry-text="node101")
			nvaMac=$(zenity --entry --text="Introduzca la nueva MAC-Address" title="Reemplazo de MAC-Addres")
			long9=${#numnodomac}
			if [ $long9 != 7 ]; then
				zenity --error --title="Error" --text="Longitud del nodo incorrecta"
			else
				replace_node $numnodomac $nvaMac
			fi
		;;
		$op5ConMod)	#"Apply_Bios_Settings"
			exec 3> >(zenity --progress --title="Ejecutando Apply_bios..." --pulsate --auto-close --auto-kill)
		 	modificarBios>&3
		  	exec 3>&-
		;;
		*)
			zenity --Error --text="Error"
			exit
		;;
	esac
	done
}

#SUB-MENU falla de conexion
