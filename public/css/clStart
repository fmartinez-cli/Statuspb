while opcion="$(zenity --title "CLUSTER TEST" --height=280 --width=300 --list --text="Principal" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE 	"Correr todo" \
	FALSE 	"Menu de pruebas" \
	FALSE 	"Menu Verificar" \
	FALSE 	"Menu Modificar" \
	FALSE 	"Abrir Cluster anterior" \
	FALSE	"Ayuda ")"; do

	op1="Correr todo"
	op2="Menu de pruebas"
	op3="Menu Verificar"
	op4="Menu Modificar"
	op5="Abrir Cluster anterior"
	op6="Ayuda "

	#---------------------------------------------
	#VARIABLE "fail" VUELVE SIEMPRE A "0" PARA EVITAR ERRORES
	fail=0
	case $opcion in
		#--CORRER TODOS
		$op1)
			validSnRack
			if [ "$fail" == 0 ]; then
				if [ -e /kit/macaddrs/$snRack.csv ]; then
					rm -rf /opt/clustertest/logs/*.csv
					ct_configure_vm $snRack | zenity --progress --width=200  --pulsate --text="Corriendo ct_configure_vm"  --title="CT_CONFIGURE_VM" --auto-close --auto-kill
					exec 3> >(zenity --progress --title="Verificando servicios" --pulsate --auto-close --auto-kill)
					VerificarServicios>&3
					exec 3>&-
					testnodes.pl &
					exec 3> >(zenity --progress --title="ENCENDER UIDS" --percentage=0 --auto-close --auto-kill)
					temporizador>&3
					exec 3>&-
					if zenity --question --title="Verificacion" --text="El Rack paso todas las pruebas de CLUSTER?" --cancel-label="NO" --ok-label="SI"; then
						zenity --info --title="Verificacion" --text="Verificando Serial y Asset de nodos"
						exec 3> >(zenity --progress --title="Espere por favor" --pulsate --auto-close --auto-kill)
						modificarInformacion>&3
						exec 3>&-
						zenity --info --text="Presione OK para subir los Logs al FTP" --title="Subir Logs"
						valWrk
					else
						zenity --error --title="Error" --text="Fallo testnodes.pl"
					fi
				else
					zenity --error --title="Error" --text="No se encontraron MAC-address"
				fi
			else
				fail=$fail+1
			fi
		;;
		#--MENU DE CORRER POR SEPARADO
		$op2)
			menuCorrerSep
		;;
		#--MENU DE VERIFICAR INFORMACION
		$op3)
			menuVer
		;;
		#--MENU DE MODIFICAR INFORMACION
		$op4)
			menuMod
		;;
		#--ABRIR ULTIMO CLUSTER
		$op5)
			if [ -d /opt/clustertest/logs/under_test/ ];then
				zenity --info --title="Test Nodes" --text="Corriendo Clustertest"
				log=$(ls -lt /opt/clustertest/logs/ |grep under_test | cut -d "/" -f 5)
				testnodes.pl /opt/clustertest/logs/$log &
			else
				zenity --error --title="Error" --text="No se encontro informacion"
			fi
		;;
		#--ERROR
		$op6)
			firefox http://172.16.5.10/Ayuda/ayuda.html
		;;
		*)
			zenity --Error --text="Error"
			exit
		;;
		#--
	esac
done
