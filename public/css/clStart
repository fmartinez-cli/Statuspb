	zenity --info --text="Revise cableado del nodo que no conecta" --title="Falla conexion"
	opcionCon=$(zenity --title "CLUSTER TEST" --height=280 --width=300 --list --text="ping" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE "Hacer \"PING\"" \
	FALSE "Regresar a menu principal")

	op1Con="Hacer \"PING\""
	op2Con="Regresar a menu principal"
	case $opcionCon in
		$op1Con)
			pingNode
		;;
		$op2Con)
			x=1
		;;
	esac
}

#SUB-MENU reiniciar servicios
function menuReinicioServicios {
	while opcionReiServ="$(zenity --title "CLUSTER TEST" --height=280 --width=300 --list --text="Reiniciar servicios" --column="" --column="Seleccione una opcion" --radiolist \
	TRUE "OPENIB" \
	FALSE "DHCP" \
	FALSE "SSH ")"; do
	op1ReiServ="OPENIB"
	op2ReiServ="DHCP"
	op3ReiServ="SSH "
	case $opcionReiServ in
		$op1ReiServ)
			service openibd restart | zenity --progress --title="Reiniciando Servicios" --text="Servicio OPENIBD" --pulsate --auto-close --auto-kill
			zenity --info --title="Servicios" --text="Servicio \"OPENIB\" Reiniciado"
		;;
		$op2ReiServ)
			service dhcpd restart | zenity --progress --title="Reiniciando Servicios" --text="Servicio DHCP" --pulsate --auto-close --auto-kill
			zenity --info --title="Servicios" --text="Servicio \"DHCPD\" Reiniciado"
		;;
		$op3ReiServ)
			service sshd restart | zenity --progress --title="Reiniciando Servicios" --text="Servicio SSH" --pulsate --auto-close --auto-kill
			zenity --info --title="Servicios" --text="Servicio \"SSH\" Reiniciado"
		;;
		$*)
			zenity --error --title="ERROR" --text="FALLA DE SISTEMA"
		;;
	esac
	done
}

