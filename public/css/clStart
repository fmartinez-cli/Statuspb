#VERIFICAR SERVICIOS
function VerificarServicios {
	serOpen=$(service openibd status 	| grep HCA 		| cut -d " " -f 4)
	serDhcp=$(service dhcpd status 		| grep dhcpd 		| cut -d " " -f 3)
	servSsh=$(service sshd status 		| grep is 		| cut -d " " -f 3)

	echo "# Verificando servicios"
	#OPENIB
	if [ $serOpen == "not" ]; then
		service openibd start
		sleep 3
	fi
	#DHCP
	if [ $serDhcp == "stopped" ]; then
		service dhcpd start
		sleep 3
	fi
	#SSH
	if [ $servSsh == "stopped" ]; then
		service sshd start
		sleep 3
	fi
}

#VERIFICAR NUMERO DE SERIE
function verificarSerial {
	echo "# Esperando Numeros de Serie"
	pdsh -a -x node100 dmidecode -t1 | grep Serial | sort >> /root/Serial.txt
	if [ -s /root/Serial.txt ];then
		verifNumSeriales = `wc -l /root/Serial.txt`
		declare -i verifNumSeriales=$verifNumSeriales
		if [ "$verifNumSeriales" = "36" ]; then
			echo "$verifNumSeriales Nodos arrojaron informacion" >> /root/Serial.txt
			zenity --text-info --width=390 --height=600 --filename=/root/Serial.txt --title="Numeros de Serie"
			sleep 1
		else
			let verifNumSeriales=36 - $verifNumSeriales
			echo "$verifNumSeriales Nodos no arrojaron Numero de Serie" >> /root/Serial.txt
			sleep 1
		fi
	else
		zenity --error --title="ERROR" --text="No se encontraron numeros de serie"
		sleep 1
	fi
	rm -f /root/Serial.txt
	sleep 1
}

#VERIFICAR ASSET TAG
function verificarAsset {
	echo "# Esperando ASSET TAGs"
	pdsh -a -x node100 dmidecode -t3 | grep Asset | sort >> /root/Asset.txt
	if [ -s /root/Asset.txt ];then
		declare -i numAssets = `wc -l /root/Asset.txt`
		if [ "$numAssets" = "36" ]; then
			echo "$numAssets Nodos arrojaron informacion" >> /root/Asset.txt
			zenity --text-info --width=390 --height=600 --filename=/root/Asset.txt --title="Numeros de Serie"
			sleep 1
		else
			let numAssets=36 - $numAssets
			echo "$numAssets Nodos no arrojaron Numero de Serie" >> /root/Asset.txt
			sleep 1
		fi
		zenity --text-info --width=390 --height=600 --filename=/root/Asset.txt --title="Asset Tags"
		rm -f /root/Asset.txt
		sleep 1
	else
		zenity --error --title="ERROR" --text="No se encontraron Asset Tags"
