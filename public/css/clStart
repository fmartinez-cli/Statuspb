#VALIDAR NUMERO DE SERIE DE RACK
function validSnRack {
	fail=0
	snRack=$(zenity --entry --text="Introduzca Numero de Serie del Rack" --title="Numero de Serie")
	#--Mayusculas
	snRack=$(echo $snRack | tr [:lower:] [:upper:])
	#--Validar Longitud
	formatSnRack=$(echo $snRack | cut -c 1-3)
	longSnRack=${#snRack}
	if [ $longSnRack != 10 ]; then
		zenity --error --title="Error" --text="Longitud del N/S incorrecta"n
		fail=$fail+1
	else
	#--Validar Formato
		if [ $formatSnRack != "2M2" ]; then
			zenity --error --title="Error" --text="Formato del N/S incorrecta"
			fail=$fail+1
		fi
	fi
}

